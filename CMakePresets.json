{
  "version": 3,
  "configurePresets": [
    {
      "name": "wsl-debug",
      "displayName": "WSL: Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "vendor": {
        "microsoft.com/Visual StudioSettings/CMake/1.0": {
          "hostOS": [ "Linux" ]
        }
      }
    }
  ]
}